    <bpmn:messageFlow id="Flow_11imbap" sourceRef="Event_1rwxsnh" targetRef="Participant_0d0ei5y" />
    <bpmn:textAnnotation id="TextAnnotation_0wvdytk">
      <bpmn:text>Entregam nova password directamente ao utilizador.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0emvf7k">
      <bpmn:text>AD Manager, Magda</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0c9tgny">
      <bpmn:text>Se a VPN é de um utilizador da justiça, o reset pode ser executado pela equipa de Sistemas.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0q7l1hf">
      <bpmn:text>Se o utilizador contactar a partir de um número móvel, o pedido só é aceite se a solicitação for efetuada  pelo superior hierárquico.
Se o contacto for por e-mail,
o pedido pode ser aceite.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1y4pget">
      <bpmn:text>Via Office 365</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_095d06j" sourceRef="Activity_0ogqkz4" targetRef="TextAnnotation_1y4pget" />
    <bpmn:association id="Association_12xbf9f" sourceRef="Activity_1gw9iou" targetRef="TextAnnotation_0emvf7k" />
