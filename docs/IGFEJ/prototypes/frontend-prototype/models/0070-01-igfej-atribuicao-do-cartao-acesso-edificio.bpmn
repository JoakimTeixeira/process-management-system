    <bpmn:textAnnotation id="TextAnnotation_1n7gapi">
      <bpmn:text>Dados disponibilizados: Nome Completo,
Nº do CC, E-mail externo, Categoria - Consultor
(categoria aplicada aos colaboradores externos),
Edifício e pisos aos quais pode aceder; Entidade (IGFEJ); Departamento, NºSAP (Não se aplica,
apenas para colaboradores internos)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1gzkrta">
      <bpmn:text>CC do email:
Diretor do Departamento</bpmn:text>
    </bpmn:textAnnotation>
