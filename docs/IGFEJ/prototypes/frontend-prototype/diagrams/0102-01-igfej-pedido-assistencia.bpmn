    <bpmn:textAnnotation id="TextAnnotation_0irk8ga">
      <bpmn:text>Nota: via PDA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0nwp2my">
      <bpmn:text>Nota: via PDA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1sakjt9">
      <bpmn:text>Nota: opcional</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0pcrzox">
      <bpmn:text>Nota: insere observação</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_09n6kqu">
      <bpmn:text>Nota: pedido por ser criado diretamente no PDA ou ser pedido a algum membro da equipa por e-mail, telefone ou pessoalmente</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1eu12bc">
      <bpmn:text>Nota: através do software PDA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_19ubphn">
      <bpmn:text>Nota: apenas via PDA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1qa7uk4">
      <bpmn:text>Nota: registo criado no PDA com atribuição a um membro da equipa de apoio local</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_01eg2d6">
      <bpmn:text>Nota: pedido é  avocado no software PDA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1fht9o8">
      <bpmn:text>Nota: O membro da equipa de apoio local selecionado para realizar o pedido de assistência poderá ser diferente do membro inicialmente selecionado na fase de análise do pedido.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0sdj1jd">
      <bpmn:text>Nota: por vezes, o pedido pode necessitar de aprovação de um superior hierárquico.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_10fc5ul">
      <bpmn:text>Nota: insere observação</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_17tjed6">
      <bpmn:text>Nota: insere observação</bpmn:text>
    </bpmn:textAnnotation>
