    <bpmn:textAnnotation id="TextAnnotation_09n6kqu">
      <bpmn:text>Nota: pedido feito por e-mail para o endereço apoio@igfej.mj.pt</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0n5r62u">
      <bpmn:text>Nota1: pedido feito por email diretamente para a equipa de servidores                                Nota2: certificados digitais para servidores ou sítios web</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0gye72i">
      <bpmn:text>Nota: no sistema Easyvista</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0bjwtt8">
      <bpmn:text>Nota: no sistema AD Manager</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1n8vnpr">
      <bpmn:text>Nota: são enviados 2
e-mails ao remetente.
Um com o certificado gerado
e outro com a palavra-chave</bpmn:text>
