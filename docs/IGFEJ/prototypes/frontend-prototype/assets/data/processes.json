            "code": "9.1",
            "title": "Redefinição de Password (Apps)",

            "entity": ["IGFEJ"],
            "responsible": ["Service Desk"],
            "description": "Fluxo específico para redefinir password em aplicações/sistemas (além do diretório).",
            "keywords": ["password", "apps", "reset", "acesso"],
            "objectives": [
              "Restaurar acesso a aplicações com controlo e evidência",
              "Garantir validação do utilizador antes do reset"
            ],
            "inputs": [
              "Pedido de reset",
              "Identificação do utilizador",
              "Aplicação alvo"
            ],

            "activities": {
              "description": "Atividades para validar o pedido, executar a redefinição na aplicação e encerrar com evidência registada.",
              "items": [
