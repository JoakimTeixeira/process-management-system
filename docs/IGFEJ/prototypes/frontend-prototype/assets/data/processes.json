    "versions": [
      {
        "id": "f3c78c4a-8d8d-4df2-bf8e-4b0df3a8a901",
        "process_id": "7f1a42f9-3d7b-4ef2-8d28-1a4f3c9c7b11",
        "version": "1.0",
        "code": "7.0",
        "author_id": "user-001",
        "updated_by": "user-001",
        "change_description": "Versão inicial (AS-IS) com subprocesso principal de gestão de incidentes.",
        "created_at": "2026-01-10T10:00:00Z",
        "updated_at": "2026-03-14T10:00:00Z",
        "subprocesses": [
          {
            "id": "d9e6c2f4-14d2-4db3-8b73-5742d4fd5e10",
            "code": "7.1",
            "title": "Gestão de Incidentes",
            "entity": [
              "Instituto de Gestão Financeira e Equipamentos da Justiça (IGFEJ)"
            ],
            "responsible": ["Não identificado"],
            "description": {
              "blocks": [
                {
                  "type": "text",
                  "text": "A gestão de incidentes é uma prática essencial do ITIL (Information Technology Infrastructure Library) que visa restaurar a operação normal de um serviço de TI o mais rapidamente possível e minimizar o impacto negativo no negócio."
                },
                {
                  "type": "text",
                  "text": "Benefícios da Gestão de Incidentes"
                },
                {
                  "type": "list",
                  "items": [
                    {
                      "text": "Melhoria da Satisfação do Cliente",
                      "description": "Rápida resolução de problemas aumenta a satisfação dos utilizadores.",
                      "children": []
                    },
                    {
                      "text": "Redução de Impacto no Negócio",
                      "description": "Minimiza interrupções e perdas financeiras associadas a incidentes.",
                      "children": []
                    },
                    {
                      "text": "Melhoria da Eficiência Operacional",
                      "description": "Processos padronizados e bem definidos aumentam a eficiência da equipa de suporte.",
                      "children": []
                    },
                    {
                      "text": "Base para Melhoria Contínua",
                      "description": "Lições aprendidas ajudam a prevenir futuros incidentes e a melhorar os processos de gestão.",
                      "children": []
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "A gestão eficaz de incidentes é crucial para a operação de TI e contribui significativamente para a continuidade e qualidade dos serviços prestados."
                }
              ]
            },
            "keywords": ["igfej", "gestão de incidentes"],
            "objectives": [
              "Restaurar o serviço rapidamente: o principal objetivo é restabelecer a operação normal do serviço o mais rapidamente possível.",
              "Minimizar impacto: Reduzir o impacto negativo no negócio causado por interrupções no serviço.",
              "Garantir a qualidade do serviço: Manter a qualidade e disponibilidade do serviço de TI."
            ],
            "inputs": [
              "Informação/Detalhes sobre a situação manifestada no incidente"
            ],
            "activities": {
              "blocks": [
                {
                  "type": "text",
                  "text": "Para fazer a abertura de um incidente, são executadas as seguintes atividades:"
                },
                {
                  "type": "list",
                  "items": [
                    {
                      "text": "Validar ocorrência",
                      "description": "O Service Desk valida a ocorrência reportada por utilizadores, entidades externas, equipas de suporte ou sistemas de monitorização automática e decide se reúne os dados necessários para registo.",
                      "children": []
                    },
                    {
                      "text": "Registar detalhes da ocorrência",
                      "description": "O incidente é registado na ferramenta de gestão de incidentes com data, hora, descrição, utilizador afetado, aplicações e sistemas envolvidos.",
                      "children": []
                    },
                    {
                      "text": "Classificar incidente",
                      "description": "O incidente é classificado quanto a urgência e impacto para determinar a prioridade de resposta.",
                      "children": []
                    },
                    {
                      "text": "Triagem inicial",
                      "description": "A equipa de suporte realiza um diagnóstico inicial e pesquisa na Knowledge Base para identificar uma solução rápida.",
                      "children": []
                    },
                    {
                      "text": "Obter solução da KB",
                      "description": "Quando existe solução conhecida, esta é comunicada ao utilizador ou aplicada pela equipa; caso contrário, o incidente segue para investigação.",
                      "children": []
                    },
                    {
                      "text": "Assignar incidente",
                      "description": "O incidente é encaminhado para a equipa ou linha de suporte adequada de acordo com regras de decisão previamente definidas.",
                      "children": []
                    },
                    {
                      "text": "Investigar e diagnosticar (L1)",
                      "description": "A primeira linha de suporte analisa logs, executa testes e procura uma solução viável para restabelecer o serviço.",
                      "children": []
                    },
                    {
                      "text": "Gestão de problemas (L2)",
                      "description": "Quando necessário, o incidente é aprofundado por equipas especializadas e programadores para identificação da causa raiz e solução técnica.",
                      "children": []
                    },
                    {
                      "text": "Resolver e recuperar",
                      "description": "A solução é implementada, o serviço é restaurado e são realizados testes de validação do funcionamento normal.",
                      "children": []
                    },
                    {
                      "text": "Fechar incidente",
                      "description": "O registo é atualizado com os detalhes da resolução, confirmação do restabelecimento e eventuais ações futuras.",
                      "children": []
                    },
                    {
                      "text": "Conclusão",
                      "description": "Após notificação ao utilizador, quando aplicável, o processo é concluído.",
                      "children": []
                    }
                  ]
                }
              ]
            },
            "deliverables": [
              "Solução implementada para o incidente",
              "Identificação da causa provável ou causa raiz",
              "Registo atualizado com evidências de tratamento e resolução"
            ],
            "suppliers": ["Nada a referir"],
            "participants": [
              "Utilizadores finais",
              "Fornecedores",
              "Equipas técnicas do IGFEJ",
              "Service Desk",
              "Equipas de suporte L1 e L2"
            ],
            "clients": ["Utilizadores finais", "Fornecedores"],
            "methodologies": ["ITIL", "Gestão de Incidentes"],
            "tools": [
              "Ferramenta de ITSM",
              "Knowledge Base (KB)",
              "Ferramentas de monitorização",
              "Sistemas de logging"
            ],
            "metrics": {
              "blocks": [
                {
                  "type": "list",
                  "items": [
                    {
                      "text": "Tempo de resolução de incidentes (MTTR - Mean Time to Resolve)",
                      "description": "Média de tempo para resolver incidentes",
                      "children": []
                    },
                    {
                      "text": "Taxa de reabertura de incidentes",
                      "description": "Percentagem de incidentes reabertos",
                      "children": []
                    },
                    {
                      "text": "Número de incidentes por categoria",
                      "description": "Contagem de incidentes por tipo",
                      "children": []
                    },
                    {
                      "text": "Tempo médio de resposta (Mean Time to Respond)",
                      "description": "Média de tempo para primeira resposta",
                      "children": []
                    },
                    {
                      "text": "Satisfação do utilizador (CSAT)",
                      "description": "Índice de satisfação do cliente",
                      "children": []
                    }
                  ]
                }
              ]
            },
            "maturity": ["Nada a referir"],
            "itsm_request": ["Gestão de Incidentes"],
            "cmdb_service": ["Gestão de Incidentes"],
            "suggestions": {
              "blocks": [
                {
                  "type": "text",
                  "text": "Nada a referir"
                }
              ]
            },
            "legal_support": {
              "blocks": [
                {
                  "type": "text",
                  "text": "Nada a referir"
                }
              ]
            },
            "information_classification": {
              "blocks": [
                {
                  "type": "text",
                  "text": "Nada a referir. Ex.: Confidencial, Restrito, Interno, Público."
                }
              ]
            },
            "metadata": {
              "interviewer": "João Caldeira (08/07/2024)",
              "interviewed": ["NA"]
            }
          }
        ],
        "assets": [
