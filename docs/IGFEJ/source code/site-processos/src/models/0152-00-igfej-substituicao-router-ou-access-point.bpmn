    <bpmn:textAnnotation id="TextAnnotation_0hlmm2c">
      <bpmn:text>Nota: Armazém do IGFEJ</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1o8pm5o">
      <bpmn:text>Nota: equipamento enviado para o local via CTT com registo e aviso de receção</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1scbo0b">
      <bpmn:text>Nota: atividade realizada pelo coordenador da equipa de apoio local</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0n5r62u">
      <bpmn:text>Nota: pedido efetuado por telefone diretamente para a equipa de redes
(se for urgente).
Se não for urgente, o pedido será feito por e-mail</bpmn:text>
    </bpmn:textAnnotation>
