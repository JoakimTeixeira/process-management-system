    <bpmn:textAnnotation id="TextAnnotation_02jzjde">
      <bpmn:text>nota: pasta identificada com número de cartão de cidadão (chave de pesquisa) e possível de ser pesquisada no Forcebo</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0bdizhf" associationDirection="None" sourceRef="Activity_0wh2o8u" targetRef="TextAnnotation_02jzjde" />
    <bpmn:textAnnotation id="TextAnnotation_033qjb5">
      <bpmn:text>nota: validar o email profissional na AD e o nome do titular no ficheiro de registo</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0t9yepm" sourceRef="Activity_0xo4hoq" targetRef="TextAnnotation_033qjb5" />
    <bpmn:textAnnotation id="TextAnnotation_1ct1s8l">
      <bpmn:text>nota: o pedido é deferido e passa automaticamente via aplicação "Forcebo" para a impressora de cartões, que lê e valida os dados e faz ligação ao CEGER para aplicação automática do certificado digital no cartão</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0uk2hk9" sourceRef="Activity_0reukif" targetRef="TextAnnotation_1ct1s8l" />
    <bpmn:textAnnotation id="TextAnnotation_07sez1a">
      <bpmn:text>nota: a impressora automaticamente dobra o documento e fecha o envelope com cola</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0jqvhnl" sourceRef="Activity_0bjkc9g" targetRef="TextAnnotation_07sez1a" />
  </bpmn:collaboration>
