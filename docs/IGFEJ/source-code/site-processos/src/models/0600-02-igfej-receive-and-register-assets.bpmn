    <bpmn:textAnnotation id="TextAnnotation_0qabx7g">
      <bpmn:text>Agendar datas de entrega dos bens</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0y2a022">
      <bpmn:text>Dados: Informação do Nºcontrato, Data de entrega, Quantidade, Garantias, etc.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0x0hfdl">
      <bpmn:text>Instalar imagem, Instalar SO, 
Configurar Equipamento</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0w2534h">
      <bpmn:text>Aguardar pela recepção dos equipamentos em falta</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0shcrmi" associationDirection="None" sourceRef="Flow_1vc43bp" targetRef="TextAnnotation_0w2534h" />
    <bpmn:textAnnotation id="TextAnnotation_0zzo2kz">
      <bpmn:text>Esta atividade é automática</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1h4jfj8">
      <bpmn:text>Comunicação realizada via
e-mail, telefone</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0iivave">
      <bpmn:text>Esta tarefa é automática e tem associada uma tabela de regras</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_19v4d3o">
