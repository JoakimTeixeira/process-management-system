    <bpmn:textAnnotation id="TextAnnotation_0n5r62u">
      <bpmn:text>Nota1: pedido feito por e-mail diretamente para a equipa de servidores                                Nota2: certificados digitais para servidores ou sítios web</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1racloj" associationDirection="None" sourceRef="Activity_1wtrpcm" targetRef="TextAnnotation_0n5r62u" />
    <bpmn:textAnnotation id="TextAnnotation_1n8vnpr">
      <bpmn:text>Nota: é enviado ao remetente e-mail com informação sobre sucesso na instalação do certificado no servidor ou são enviados 2
e-mails. Um com o certificado gerado e outro com a palavra-chave</bpmn:text>
    </bpmn:textAnnotation>
