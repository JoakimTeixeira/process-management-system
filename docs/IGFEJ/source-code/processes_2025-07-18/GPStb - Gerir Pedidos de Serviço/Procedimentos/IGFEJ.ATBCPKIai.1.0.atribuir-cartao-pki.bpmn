    <bpmn:textAnnotation id="TextAnnotation_09n6kqu">
      <bpmn:text>Nota: pedido é realizado presencialmente pelo titular junto de um técnico da equipa de apoio local</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_108iwqq" sourceRef="Activity_1qul8ob" targetRef="TextAnnotation_09n6kqu" />
    <bpmn:textAnnotation id="TextAnnotation_1qa7uk4">
      <bpmn:text>Nota: pedido criado no "Portal de Cliente" na opção "Pedido de Cartão"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0cl4852">
      <bpmn:text>Nota: template word
impresso preenchido com dados pessoais do titular</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_18cflun">
      <bpmn:text>Nota: template de contrato digital no "Portal de Cliente" preenchido com os dados pessoais do titular</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0v722nz">
      <bpmn:text>Nota: via e-mail</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ctp7l8">
      <bpmn:text>Nota: modo presencial</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1rixfpi">
      <bpmn:text>Nota: modo  presencial</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0yw1li6">
      <bpmn:text>Nota: modo presencial</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0wqq224">
      <bpmn:text>Nota: entregue em mãos ou via e-mail consoante o tipo de contrato</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11mqgrr">
      <bpmn:text>Nota: no "Portal de Cliente"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0jgrwfo">
      <bpmn:text>Nota: através da passagem do pedido para o estado "Pedido" no "Portal de cliente"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0b0tn32" sourceRef="Activity_08csuqk" targetRef="TextAnnotation_0cl4852" />
    <bpmn:association id="Association_1di7zei" associationDirection="None" sourceRef="Activity_16d4k8p" targetRef="TextAnnotation_0ctp7l8" />
    <bpmn:association id="Association_0cg95mv" associationDirection="None" sourceRef="Activity_0ingsid" targetRef="TextAnnotation_0v722nz" />
    <bpmn:association id="Association_0hp4h3f" sourceRef="Activity_0xpvalu" targetRef="TextAnnotation_18cflun" />
    <bpmn:association id="Association_1qn1jsz" sourceRef="Activity_1i2hz8y" targetRef="TextAnnotation_1qa7uk4" />
    <bpmn:textAnnotation id="TextAnnotation_13ytugc">
      <bpmn:text>Nota: Assinatura física ou digital consoante o tipo de contrato</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_06m8h98">
      <bpmn:text>Nota: via e-mail</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0bmr1lz" sourceRef="Activity_1fsxfbf" targetRef="TextAnnotation_0yw1li6" />
    <bpmn:association id="Association_12yhz6i" associationDirection="None" sourceRef="Activity_1ub9h3r" targetRef="TextAnnotation_1rixfpi" />
    <bpmn:textAnnotation id="TextAnnotation_049nf22">
      <bpmn:text>Nota: documentos arquivados em pasta segura em servidor seguro</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_14057yj">
      <bpmn:text>Nota: via e-mail para: pki@igfej.mj.pt</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1w8sxxg">
      <bpmn:text>Nota: via CTT</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0r07gii">
      <bpmn:text>Nota: via CTT</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1l76nls">
      <bpmn:text>Nota: contrato físico arquivado em dossier</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_033qjb5">
      <bpmn:text>Nota: na lista de pedidos da aplicação "Forcebo"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1rx43j7">
      <bpmn:text>Nota: validar o e-mail profissional na AD e o nome do titular na
listagem CCM em pdf</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ct1s8l">
      <bpmn:text>Nota: o pedido é deferido e passa automaticamente via aplicação "Forcebo" para a impressora de cartões, que lê, valida os dados e faz ligação ao CEGER para aplicação automática do certificado digital no cartão</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0by6oy1" associationDirection="None" sourceRef="Activity_0ehe5c3" targetRef="TextAnnotation_0wqq224" />
    <bpmn:textAnnotation id="TextAnnotation_0aywfmt">
      <bpmn:text>Nota: via e-mail para:  pki@igfej.mj.pt</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1bzivl6" sourceRef="Activity_095fipe" targetRef="TextAnnotation_13ytugc" />
    <bpmn:textAnnotation id="TextAnnotation_07sez1a">
      <bpmn:text>Nota: a impressora automaticamente dobra o documento e fecha o envelope com cola</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0iqjv97">
      <bpmn:text>Nota: informa o técnico que solicitou o pedido que o mesmo foi indeferido e fechado</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_05s4f93">
      <bpmn:text>Nota: e-mail automático com comunicação de emissão do cartão PKI e link para posterior ativação</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0f06qor">
      <bpmn:text>Nota: na aplicação "Forcebo"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1gnimz5">
      <bpmn:text>Nota: na aplicação "Forcebo"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1g54i2i">
      <bpmn:text>Nota: o operador dobra manualmente o documento com cartão e insere-o dentro do envelope, fechando-o com cola</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0j0khen">
      <bpmn:text>Nota: feito manualmente pelo técnico</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11imrzw">
      <bpmn:text>Nota: recebe em mãos</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0t19cid">
      <bpmn:text>Nota: recebe em mãos</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1xfapfc">
      <bpmn:text>Nota: carta enviada para a morada não-institucional do titular tem como destinatário o titular</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_09416rw">
      <bpmn:text>Nota: carta enviada para a morada institucional do titular e tem como destinatário o técnico de apoio local</bpmn:text>
    </bpmn:textAnnotation>
